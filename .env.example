# =========================================
# BACKBLAZE B2 STORAGE CONFIGURATION
# =========================================
VITE_B2_KEY_ID=your_backblaze_key_id_here
VITE_B2_APPLICATION_KEY=your_backblaze_application_key_here
VITE_B2_ENDPOINT=s3.your-region-003.backblazeb2.com
VITE_B2_BUCKET_NAME=your_bucket_name_here
VITE_B2_REGION=your-region-003
